# ── AIR_SENSE .env.example ────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual keys

# API Keys
AQICN_TOKEN=your_aqicn_token_here
OPENWEATHER_KEY=your_openweather_key_here

# City
CITY_NAME=Delhi
LATITUDE=28.6139
LONGITUDE=77.2090

# Backend
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./airvision.db
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# App
DEBUG=True
PORT=8000
